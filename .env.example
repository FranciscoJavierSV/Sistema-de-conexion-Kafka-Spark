# Proyecto Kafka-Spark - archivo .env
# Edita los valores según tu red antes de arrancar los contenedores

# Brokers (lista separada por comas) usada por producer/consumer
BROKERS=100.100.10.100:9094,100.100.10.100:9096,100.100.10.100:9098

# Quorum de controllers (formato: id@host:controllerPort,...)
CONTROLLER_VOTERS=1@100.100.10.100:9093,2@100.100.10.101:9093,3@100.100.10.102:9093

# Cluster id (mantener el mismo en los 3 nodos KRaft)
CLUSTER_ID=5L6g3nShT-eMCtK--X86sw

# IP anunciada por este host (cámbiala si corres en un host físico)
ADVERTISED_IP=100.100.10.100
HOST_PORT=9094
NODE_ID=1

# Kafka tuning
KAFKA_AUTO_CREATE_TOPICS_ENABLE=false
KAFKA_NUM_PARTITIONS=3
KAFKA_DEFAULT_REPLICATION_FACTOR=3
KAFKA_MIN_INSYNC_REPLICAS=2

# Spark (si usas variables desde los run scripts)
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_PORT=7077

# Nota:
# - Si vas a ejecutar los contenedores en máquinas físicas, copia este .env a cada host
#   y actualiza ADVERTISED_IP y NODE_ID (y opcionalmente HOST_PORT).
# - Para uso en Docker en una sola máquina, estos valores funcionan con los run.sh actuales.
# - Si prefieres, renombra este archivo a .env.local y añade .env a .gitignore para no subirlo.
